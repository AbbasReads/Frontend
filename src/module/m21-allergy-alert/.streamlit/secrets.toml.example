# Streamlit Secrets Configuration for MongoDB Atlas
# Copy this file to secrets.toml and update with your MongoDB Atlas connection string

[default]
MONGODB_URL = "mongodb+srv://username:password@cluster.mongodb.net/m21_allergy_alert?retryWrites=true&w=majority"

# Alternative format for environment-specific configs
[production]
MONGODB_URL = "mongodb+srv://username:password@cluster.mongodb.net/m21_allergy_alert?retryWrites=true&w=majority"

[development]
MONGODB_URL = "mongodb://localhost:27017/"